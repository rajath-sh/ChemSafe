# ═══════════════════════════════════════════════════════════
# ChemSafe IoT — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Database Mode ──
# "sqlite"   → Local SQLite database (no setup needed)
# "firebase" → Firebase Firestore (requires service account key)
DB_MODE=sqlite

# ── SQLite Settings (only when DB_MODE=sqlite) ──
SQLITE_URL=sqlite:///./chemsafe.db

# ── Firebase Settings (only when DB_MODE=firebase) ──
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=your-project-id

# ── MQTT (HiveMQ Cloud) ──
MQTT_BROKER=your-cluster.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
MQTT_USE_TLS=true

# ── Application ──
APP_NAME=ChemSafe IoT
APP_VERSION=1.0.0
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Auth ──
# Set to "true" to skip Firebase Auth verification (dev only)
AUTH_DISABLED=true

# ── Email Notifications (SMTP) ──
# Leave blank to log emails to console (Dev Mode)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@chemsafe.local
